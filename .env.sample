# --- Firebase Configuration ---
VITE_FIREBASE_API_KEY=あなたのFirebase_API_KEY
VITE_FIREBASE_AUTH_DOMAIN=あなたのFirebase_AUTH_DOMAIN
VITE_FIREBASE_PROJECT_ID=あなたのFirebase_PROJECT_ID
VITE_FIREBASE_STORAGE_BUCKET=あなたのFirebase_STORAGE_BUCKET
VITE_FIREBASE_MESSAGING_SENDER_ID=あなたの Firebase_MESSAGING_SENDER_ID
VITE_FIREBASE_APP_ID=あなたのFirebase_APP_ID
VITE_FIREBASE_MEASUREMENT_ID=あなたのFirebase_MEASUREMENT_ID (オプション)

# --- Gemini API Configuration ---
# 自分のAPIキーを使用する場合に設定。
# ログイン（ProxyMode）のみで使用する場合は不要です。
VITE_GEMINI_API_KEY=あなたのGemini_API_KEY

# --- Vercel Proxy (Spiritual Echo) ---
# Vercel環境でビルドする場合に、プロキシAPIのパスを指定。
# デフォルトは /api/spiritual-echo
VITE_PROXY_URL=/api/spiritual-echo
